generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id               // Clerk user ID (e.g. user_2abc...)
  email          String   @unique
  firstName      String?
  lastName       String?
  plan           String   @default("free")  // free | starter | pro
  creditBalance  Int      @default(5)       // Default 5 free credits on sign up
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
